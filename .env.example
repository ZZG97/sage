# 飞书配置
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_DOMAIN=https://open.feishu.cn

# Agent Provider: 'opencode' | 'claude-code' | 'codex' | 'cc-minimax'
AGENT_PROVIDER=opencode
# AGENT_FALLBACK_PROVIDER=cc-minimax  # 可选，降级 provider

# OpenCode 配置 (AGENT_PROVIDER=opencode 时生效)
OPENCODE_BASE_URL=http://127.0.0.1:4111

# Claude Code 配置 (AGENT_PROVIDER=claude-code 时生效)
CLAUDE_CODE_WORK_DIR=/path/to/workdir
CLAUDE_CODE_MAX_TURNS=25
CLAUDE_CODE_MODEL=sonnet
# CLAUDE_CODE_ALLOWED_TOOLS=Read,Bash,Edit,Grep,Glob,WebSearch,WebFetch

# CC-MiniMax 配置 (AGENT_PROVIDER=cc-minimax 时生效，基于 Claude Code SDK + MiniMax API)
CC_MINIMAX_API_KEY=your_minimax_api_key
CC_MINIMAX_MODEL=MiniMax-M2.7
CC_MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic

# Tavily Search（CC-MiniMax 搜索工具，可选）
TAVILY_API_KEY=tvly-xxx

# Codex 配置
OPENAI_API_KEY=sk-xxx
CODEX_MODEL=gpt-5.3-codex        # 可选，默认 gpt-5.3-codex
CODEX_WORK_DIR=~/workspace/sage/agent_home  # 可选
CODEX_SANDBOX_MODE=danger-full-access       # 可选

# 服务器配置
PORT=3000
HOST=0.0.0.0
NODE_ENV=development