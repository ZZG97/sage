# 飞书配置
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_DOMAIN=https://open.feishu.cn

# Agent Provider: 'opencode' | 'claude-code'
AGENT_PROVIDER=opencode

# OpenCode 配置 (AGENT_PROVIDER=opencode 时生效)
OPENCODE_BASE_URL=http://127.0.0.1:4111

# Claude Code 配置 (AGENT_PROVIDER=claude-code 时生效)
CLAUDE_CODE_WORK_DIR=/path/to/workdir
CLAUDE_CODE_MAX_TURNS=25
CLAUDE_CODE_MODEL=sonnet
# CLAUDE_CODE_ALLOWED_TOOLS=Read,Bash,Edit,Grep,Glob,WebSearch,WebFetch

# 服务器配置
PORT=3000
HOST=0.0.0.0
NODE_ENV=development